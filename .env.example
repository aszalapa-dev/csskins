# Skinport — Basic Auth (client_id:client_secret encoded in Base64)
SKINPORT_CLIENT_ID=
SKINPORT_CLIENT_SECRET=

# CSFloat — API key sent as Authorization header
CSFLOAT_API_KEY=

# DMarket — HMAC-SHA256 signature with public/private key pair
DMARKET_PUBLIC_KEY=
DMARKET_PRIVATE_KEY=

# Shadowpay — Bearer token
SHADOWPAY_API_KEY=

# Waxpeer — passed as ?api= query param
WAXPEER_API_KEY=

# BitSkins — sent as X-Apikey header
BITSKINS_API_KEY=

# Vercel base URL (auto-set by Vercel in production, set manually for local dev)
# VERCEL_URL=localhost:3000
